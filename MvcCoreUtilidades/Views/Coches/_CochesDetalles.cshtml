@model Coche

<h1>Detalles</h1>
@if(Model != null)
{
    <div class="card" style="width: 18rem;">
        <img src="@Model.Imagen" class="card-img-top">
        <div class="card-body">
            <h5 class="card-title">@Model.Marca @Model.Modelo</h5>
        </div>
    </div>
}
else
{
    <h3>No existe coche</h3>
}
